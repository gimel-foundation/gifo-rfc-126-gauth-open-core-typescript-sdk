{
  "name": "@gauth/core",
  "version": "0.92.0",
  "description": "GAuth Open Core TypeScript SDK — Power-of-Attorney credentials for AI agent governance (GiFo RFCs 0116, 0117, 0118)",
  "license": "MPL-2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "ADDITIONAL-TERMS.md",
    "CONTRIBUTING.md",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "jose": "^6.0.11",
    "zod": "catalog:"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "typescript": "~5.9.2",
    "vitest": "^3.2.3",
    "@types/node": "catalog:"
  },
  "keywords": [
    "gauth",
    "authorization",
    "power-of-attorney",
    "ai-governance",
    "poa",
    "gimel-foundation",
    "oauth",
    "pep",
    "agent",
    "mandate"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Gimel-Foundation/gauth-core-ts"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
